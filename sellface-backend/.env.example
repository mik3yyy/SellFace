# Database (Neon PostgreSQL or any Postgres)
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?ssl=require
DATABASE_URL_SYNC=postgresql+psycopg2://user:password@host/dbname?sslmode=require

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Astria.ai
ASTRIA_API_KEY=your_astria_key
ASTRIA_BASE_URL=https://api.astria.ai
ASTRIA_BRANCH=flux1
ASTRIA_IMAGES_PER_JOB=8

# App
DEBUG=false
SECRET_KEY=change-me-in-production
ADMIN_SECRET=change-me-in-production

# APNs (Apple Push Notifications)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.yourcompany.SellFace
